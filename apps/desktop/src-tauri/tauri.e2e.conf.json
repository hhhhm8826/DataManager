{
  "$schema": "https://schema.tauri.app/config/2",
  "build": {
    "beforeBuildCommand": "pnpm --filter @datamanager/desktop build --mode e2e"
  },
  "app": {
    "withGlobalTauri": true,
    "security": {
      "capabilities": [
        {
          "identifier": "e2e-capability",
          "description": "Test-only permissions for the embedded WebDriver build.",
          "windows": ["main"],
          "permissions": [
            "core:default",
            "core:window:default",
            "core:window:allow-set-size",
            "dialog:allow-open",
            "wdio:default",
            "wdio-webdriver:default"
          ]
        }
      ]
    }
  }
}
