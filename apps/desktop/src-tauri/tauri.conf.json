{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "DataManager",
  "version": "0.1.1",
  "identifier": "com.datamanager.desktop",
  "build": {
    "beforeDevCommand": "pnpm --filter @datamanager/desktop dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "pnpm --filter @datamanager/desktop build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "DataManager",
        "width": 1200,
        "height": 800,
        "minWidth": 520,
        "minHeight": 640,
        "resizable": true
      }
    ],
    "security": {
      "capabilities": ["main-capability"]
    }
  },
  "bundle": {
    "active": true,
    "icon": ["icons/icon.ico"],
    "resources": {
      "../../../examples/PROTO/": "examples/PROTO/",
      "../../../examples/EXCEL/": "examples/EXCEL/",
      "../../../examples/JSON/": "examples/JSON/",
      "../../../examples/CODE/": "examples/CODE/",
      "../../../examples/PROTOC/": "examples/PROTOC/"
    },
    "targets": ["nsis"],
    "useLocalToolsDir": true
  }
}
