{
  "name": "@datamanager/desktop",
  "version": "0.1.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "tsc -b && vite build",
    "format": "prettier --write src test scripts vite.config.ts vitest.config.ts wdio.conf.mjs wdio.appdata.conf.mjs",
    "format:check": "prettier --check src test scripts vite.config.ts vitest.config.ts wdio.conf.mjs wdio.appdata.conf.mjs",
    "lint": "eslint src test scripts vite.config.ts vitest.config.ts wdio.conf.mjs wdio.appdata.conf.mjs --max-warnings=0",
    "typecheck": "tsc -b",
    "test": "vitest run --passWithNoTests",
    "test:e2e": "node ./scripts/prepare-edgedriver.mjs && wdio run ./wdio.conf.mjs && wdio run ./wdio.appdata.conf.mjs && node ./scripts/cleanup-appdata-e2e.mjs",
    "tauri": "tauri"
  },
  "dependencies": {
    "@datamanager/core": "workspace:*",
    "@tauri-apps/api": "2.11.1",
    "@tauri-apps/plugin-dialog": "2.7.1",
    "@xyflow/react": "12.10.2",
    "elkjs": "0.11.1",
    "exceljs": "4.4.0",
    "lucide-react": "^1.23.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "sonner": "2.0.7",
    "zustand": "5.0.14"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@tauri-apps/cli": "2.11.4",
    "@testing-library/dom": "10.4.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@types/node": "22.19.17",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.3",
    "@wdio/cli": "9.29.1",
    "@wdio/local-runner": "9.29.1",
    "@wdio/mocha-framework": "9.29.1",
    "@wdio/spec-reporter": "9.29.1",
    "@wdio/tauri-plugin": "1.2.0",
    "@wdio/tauri-service": "1.2.0",
    "edgedriver": "6.3.0",
    "eslint": "10.6.0",
    "eslint-plugin-react-hooks": "7.0.1",
    "eslint-plugin-react-refresh": "0.4.24",
    "jsdom": "29.1.1",
    "prettier": "3.9.4",
    "typescript": "5.9.3",
    "typescript-eslint": "8.62.0",
    "vite": "8.1.3",
    "vitest": "4.1.9"
  }
}
